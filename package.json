{
  "name": "prompt-arena",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev --name init",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "node -e \"if(process.env.NODE_ENV==='production'){console.error('ERROR: db:reset is disabled in production!');process.exit(1)}\" && npm run db:reset:dev",
    "db:reset:dev": "prisma migrate reset --force && tsx prisma/seed.ts",
    "docs": "tsx scripts/generate-docs.ts",
    "docs:watch": "tsx scripts/watch-docs.ts",
    "setup:hooks": "git config core.hooksPath .githooks",
    "postinstall": "prisma generate",
    "prepare": "[ \"$CI\" = \"true\" ] && echo 'Skipping git hooks in CI' || npm run setup:hooks",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test": "npm run test:unit && npm run test:e2e"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@types/canvas-confetti": "^1.9.0",
    "canvas-confetti": "^1.9.4",
    "next": "14.2.35",
    "prisma": "^5.22.0",
    "react": "^18",
    "react-dom": "^18",
    "tsx": "^4.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "jsdom": "^28.1.0",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "vitest": "^4.1.0",
    "wait-on": "^9.0.4"
  }
}
