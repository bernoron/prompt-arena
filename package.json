{
  "name": "prompt-arena",
  "version": "8.5.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev --name init",
    "db:seed": "tsx prisma/seed.ts",
    "db:update-learning-content": "tsx scripts/update-learning-content.ts",
    "db:reset": "node -e \"if(process.env.NODE_ENV==='production'){console.error('ERROR: db:reset is disabled in production!');process.exit(1)}\" && npm run db:reset:dev",
    "db:reset:dev": "prisma migrate reset --force && tsx prisma/seed.ts",
    "docs": "tsx scripts/generate-docs.ts",
    "docs:watch": "tsx scripts/watch-docs.ts",
    "setup:hooks": "git config core.hooksPath .githooks",
    "postinstall": "prisma generate",
    "prepare": "[ \"$CI\" = \"true\" ] && echo 'Skipping git hooks in CI' || npm run setup:hooks",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test": "npm run test:unit && npm run test:e2e",
    "test:e2e:install": "playwright install chromium",
    "test:e2e:setup": "npm run test:e2e:install",
    "security:deps": "npm audit --omit=dev --audit-level=high",
    "security:deps:all": "npm audit --audit-level=moderate"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@types/canvas-confetti": "^1.9.0",
    "better-sqlite3": "^12.11.1",
    "canvas-confetti": "^1.9.4",
    "next": "^16.2.10",
    "prisma": "^7.8.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsx": "^4.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.10",
    "jsdom": "^28.1.0",
    "postcss": "^8",
    "tailwindcss": "^4.3.2",
    "typescript": "^5",
    "vitest": "^4.1.0",
    "wait-on": "^9.0.4"
  }
}
