#!/bin/sh
#
# Pre-Commit Hook – schnelle Unit-Tests
#
# Läuft bei jedem Commit und bricht bei Fehlern ab.
# Bewusst schlank: keine Docs-/Spec-Regenerierung mit Auto-`git add` mehr
# (das mutierte bei jedem Commit den Tree). Docs/Specs werden bei Bedarf
# manuell via `npm run docs` bzw. `node scripts/spec-sync.mjs --fix` gepflegt.
#
# Einrichten (einmalig nach git clone):
#   cd prompt-arena && npm run setup:hooks
#

set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
APP_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
cd "$APP_DIR"

echo "🧪 Unit-Tests werden ausgeführt…"
npm run test:unit
echo "✅ Alle Unit-Tests bestanden."
