#!/bin/sh
#
# Pre-Commit Hook – Unit-Tests + Dokumentation
#
# Läuft bei jedem Commit:
#   1. Unit-Tests (Vitest, ~1 s) – bricht ab bei Fehler
#   2. Docs regenerieren – staged Änderungen automatisch
#
# Einrichten (einmalig nach git clone):
#   cd prompt-arena && npm run setup:hooks
#

set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
APP_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
cd "$APP_DIR"

# ── 1. Unit-Tests ─────────────────────────────────────────────────────────────
echo "🧪 Unit-Tests werden ausgeführt…"
npm run test:unit

echo "✅ Alle Unit-Tests bestanden."

# ── 2. Dokumentation aktualisieren ────────────────────────────────────────────
echo "📄 Dokumentation wird aktualisiert…"
npm run docs
git add docs/
echo "✅ Dokumentation aktualisiert und gestaged."
