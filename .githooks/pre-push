#!/bin/sh
#
# Pre-Push Hook – schnelle Gates (Sekunden), kein E2E.
#
# Läuft vor jedem git push:
#   1. TypeScript type check
#   2. ESLint
#   3. Unit-Tests (Vitest)
#
# E2E (Playwright) läuft bewusst NUR noch in CI (.github/workflows/ci.yml) —
# nicht mehr lokal. Das frühere lokale Hochfahren eines Dev-Servers + volle
# Playwright-Suite vor jedem Push war langsam, flaky (Port-Konflikte, 45s
# Warten) und hat Pushes blockiert.
#
# Einrichten (einmalig nach git clone):
#   cd prompt-arena && npm run setup:hooks
#

set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
APP_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
cd "$APP_DIR"

# Bei Tag-Push nichts prüfen (stdin: "<local-sha> <local-ref> <remote-sha> <remote-ref>").
while read local_sha local_ref remote_sha remote_ref; do
  case "$local_ref" in refs/tags/*) echo "🏷  Tag-Push erkannt – Checks übersprungen."; exit 0 ;; esac
done

echo "🔎 TypeScript type check…"
npx tsc --noEmit

echo "🧹 ESLint…"
npm run lint

echo "🧪 Unit-Tests…"
npm run test:unit

echo "✅ Alle Pre-Push-Checks bestanden."
