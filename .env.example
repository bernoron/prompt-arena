# Database
# SQLite (default for local development):
DATABASE_URL="file:./dev.db"
# PostgreSQL (for production):
# DATABASE_URL="postgresql://user:password@localhost:5432/prompt_arena"

# Admin URL path (optional — hides the admin panel behind a secret URL)
# Default: admin  → admin panel is at /admin
# Custom:  ADMIN_PATH=backstage → admin panel is at /backstage, direct /admin returns 404
# Use a random string in production to prevent enumeration.
ADMIN_PATH=

# Admin authentication (for the admin panel)
# Set any strong password here. Stored as SHA-256 hash in the session cookie.
# Set in GitHub Secrets as ADMIN_SECRET
ADMIN_SECRET=

# Optional: instantly revoke ALL admin sessions issued before this millisecond
# timestamp (without rotating ADMIN_SECRET). Generate with:
#   node -e "console.log(Date.now())"
# Leave empty unless you need to force-logout every admin session.
ADMIN_SESSION_EPOCH=

# User session signing (for cookie-based auth)
# REQUIRED in production. Must be at least 32 characters long for HMAC-SHA256.
# Without this, all write actions (submit, vote, favorite) are blocked in prod.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Set in GitHub Secrets as USER_SECRET
USER_SECRET=

# Email encryption key (for AES-256-GCM email storage)
# REQUIRED in production. Any length — hashed to 32 bytes internally.
# Without this, registration is disabled in production (503).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Set in GitHub Secrets as EMAIL_SECRET
EMAIL_SECRET=

# Outbound e-mail (password reset — CR-003)
# Default transport is "log": reset e-mails are written to the server log
# instead of being delivered — no external service needed for dev/test.
# To send real e-mails later, wire a provider in lib/mailer.ts and set these:
# MAIL_TRANSPORT=smtp            # provider name once implemented
# MAIL_FROM="PromptArena <no-reply@example.com>"
# SMTP_URL="smtp://user:pass@host:587"
MAIL_TRANSPORT=
