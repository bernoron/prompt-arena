# ─── PromptArena Environment Variables ──────────────────────────────────────
#
# Copy this file to .env and adjust values for your environment.
# Never commit your actual .env file — it is already in .gitignore.
#
# Usage:
#   cp .env.example .env
#

# ─── Database ────────────────────────────────────────────────────────────────

# SQLite file path (relative to the project root).
# For local development the default value works out of the box.
# For production, switch to an absolute path or a Postgres/MySQL URL
# if you migrate away from SQLite.
DATABASE_URL="file:./dev.db"

# ─── Runtime ─────────────────────────────────────────────────────────────────

# Node.js environment.
# Values: development | test | production
# Next.js sets this automatically; only override if you need to force a value.
NODE_ENV="development"

# ─── Logging ─────────────────────────────────────────────────────────────────

# Minimum log level emitted by the structured logger (lib/logger.ts).
#
# Values:
#   debug   – verbose; includes all SQL queries via Prisma (very noisy)
#   info    – business events, request traces (recommended for staging)
#   warn    – only warnings and errors (recommended for production)
#   error   – only errors
#
# In development the logger pretty-prints colourised output to stdout.
# In production it emits JSON-Lines (one JSON object per line) suitable
# for log aggregators such as Loki, Datadog, or AWS CloudWatch.
LOG_LEVEL="info"

# ─── Admin ────────────────────────────────────────────────────────────────────

# Password for the /admin section.
# Set this to a long, random string before deploying.
# Without this value the admin login endpoint returns 503.
#
# Generate a good secret:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
ADMIN_SECRET="change-me-before-deploy"
